---
import { Picture } from 'astro:assets'
import { getCollection, render } from 'astro:content'
import { TURNSTILE_SITE_KEY } from 'astro:env/client'
import AISummarizer from '@components/AISummarizer.astro'
import { CommentsSection } from '@components/comments'
import RelatedNotes from '@components/RelatedNotes.astro'
import ScrollTracker from '@components/ScrollTracker.svelte'
import { getPublishedNotes } from '@helpers/collections'
import { getRelatedNotes } from '@helpers/relatedNotes'
import NoteTemplate from '@templates/Note.astro'
import '@global-styles/md.css'

export async function getStaticPaths() {
  const pages = await getCollection('notas')
  const pagesTranslated = await getCollection('notes')
  return pages.map(page => {
    const pathToTranslateNote =
      pagesTranslated.find(
        translatedPage =>
          translatedPage.data.selfHealing &&
          translatedPage.data.selfHealing === page.data.selfHealing,
      )?.id || ''
    return {
      params: {
        note: page.id,
      },
      props: {
        page,
        pathToTranslateNote,
      },
    }
  })
}
const { page, pathToTranslateNote } = Astro.props

const { Content } = await render(page)
const { draft, title, publishDate, cover, coverAlt, selfHealing, description } =
  page.data

// Related posts
const allNotes = await getPublishedNotes('es')
const relatedNotes = getRelatedNotes(page, allNotes)
---
<NoteTemplate
description={description}
draft={draft}
title={title}
image={cover}
publishedAt={publishDate}
pathToTranslateNote={pathToTranslateNote}
llmPath={`/es/cuaderno/${page.id}.md`}
>
<ScrollTracker client:idle noteId={selfHealing} lang="es" threshold={0.5} />
<figure style={`view-transition-name:note-img-${page.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`}>
  {cover && coverAlt && <Picture src={cover} alt={coverAlt} width={500}/>}
  <figcaption>{coverAlt}</figcaption>
</figure>
<AISummarizer lang="es" noteId={selfHealing} />
<div id="content">
  <h1 style={`view-transition-name:note-title-${page.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`}>{title}</h1>
  <Content/>
</div>
<section class="share">
  <p>Comparte esta nota:</p>
  <p id="notification">Link copiado al portapapeles!</p>
  <button id="share" class="button button-primary" popovertarget="#share-notification">Compartir</button>
</section>
<div class="comments-wrapper">
  <CommentsSection client:load noteId={selfHealing} lang="es" turnstileSiteKey={TURNSTILE_SITE_KEY} />
</div>
<RelatedNotes notes={relatedNotes} lang="es" sourceNoteId={selfHealing} />
</NoteTemplate>
<script define:vars={{selfHealing, title}}>
  import { trackEvent } from '../../../helpers/datalayer'

  trackEvent({ event: 'note_view', note_id: selfHealing, note_title: title, category: '', lang: 'es' })

  const notification = document.getElementById('notification');
  const shareButton = document.getElementById('share');
  const urlToShare = `${window.location.href}-${selfHealing}`;

  const copyLink = async (link) => {
    if (navigator.clipboard) {
      await navigator.clipboard.writeText(link);
      notification.style.display = 'block';
      setTimeout(() => { notification.style.display = 'none'; }, 2000);
    } else {
      throw new Error('Clipboard API not supported');
    }
  };

  const shareViaShareApi = async ({ title, text, url }) => {
    if (navigator.share) {
      await navigator.share({ title, text, url });
    } else {
      throw new Error('Share API not supported');
    }
  };

  const shareContent = async () => {
    const shareData = {
      title: document.querySelector('h1').textContent,
      text: document.querySelector('meta[name="description"]').content,
      url: urlToShare,
    };
    try {
      await shareViaShareApi(shareData);
      trackEvent({ event: 'share_click', note_id: selfHealing, method: 'native', lang: 'es' })
    } catch {
      try {
        await copyLink(shareData.url);
        trackEvent({ event: 'share_click', note_id: selfHealing, method: 'copy', lang: 'es' })
      } catch (error) {
        console.error('Error copying link:', error);
      }
    }
  };
  shareButton.addEventListener('click', shareContent);
</script>
<style >
  .comments-wrapper {
    grid-column: content;
  }
  #share{
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin-top: 1rem;
    color: light-dark(var(--color-light), var(--color-dark));
    anchor-name: --share-button;
  }
  #notification{
    display:none;
    position: fixed;
    right: 10px;
    background-color: var(--color-main);
    color: white;
    padding: 10px;
    border-radius: 5px;
    z-index: 1000;
    position-anchor: --share-button;
    bottom: calc(anchor(top) + 10px);
  }
  figure {
    text-align: center;
    padding-top: 1lh;
    & img {
      margin: auto;
      border-radius: 10px;
    }
  }
  #content {
    width: 100%;
    max-width: 80ch;
    margin: auto;
    padding: 1rem;
    line-height: 1.6;
  }
</style>
