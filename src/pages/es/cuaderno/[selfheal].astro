---
import { getCollection } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const notes = await getCollection('notas')
  return notes
    .filter(note => note.data.selfHealing)
    .map(note => ({
      params: {
        selfheal: note.data.selfHealing,
      },
      props: {
        noteId: note.id.replace(/\.(md|mdx)$/, ''),
      },
    }))
}

const { noteId } = Astro.props
return Astro.redirect(`/es/cuaderno/${noteId}`, 301)
---
