---
import Badges from '@components/Badges/index.astro'
import CollectionStack from '@components/CollectionStack.astro'
import Hero from '@components/Hero.astro'
import Logos from '@components/Logos.astro'
import NotesLatest from '@components/NotesLatest.astro'
import { getLangFromUrl, useTranslations } from '@i18n/utils'
import Base from '@templates/Base.astro'

const lang = getLangFromUrl(Astro.url)

const t = useTranslations(lang)
---

<Base pathToTranslate="home">
  <Hero description={t("hero.description")} title={t("hero.title")} />
  <NotesLatest collection="notas" />
  <CollectionStack />
  <Badges title={t("badges.title")} readMore={t("badges.readMore")} />
  <section class="cta full-width">
    <blockquote>
      <p>{t("cta.description")}</p>
      <a href="/es/cuaderno" class="cta-btn">{t("cta.action")}</a>
    </blockquote>
  </section>
  <Logos />
  <style>
    .cta {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 28rem;
      background: light-dark(
        rgba(15, 40, 100, 0.08),
        rgba(10, 26, 53, 0.55)
      );
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      border-block: 1px solid light-dark(
        rgba(15, 40, 100, 0.1),
        rgba(255, 255, 255, 0.06)
      );
    }

    blockquote {
      max-width: 640px;
      padding: 0 2rem;
      margin: 0;
      position: relative;
      animation: cta-parallax linear both;
      animation-timeline: view();
      animation-range: entry 0% exit 100%;
    }

    @keyframes cta-parallax {
      from { transform: translateY(120px) scale(0.95); }
      to   { transform: translateY(-120px) scale(1.05); }
    }

    blockquote::before {
      content: '\201C';
      position: absolute;
      top: -2rem;
      left: 1rem;
      font-size: 8rem;
      line-height: 1;
      color: light-dark(rgba(15,40,100,0.15), rgba(255,255,255,0.1));
      font-family: Georgia, serif;
      pointer-events: none;
    }

    blockquote p {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-style: italic;
      font-weight: 600;
      color: light-dark(var(--color-main), white);
      line-height: 1.3;
      margin: 0 0 2rem;
      text-wrap: balance;
    }

    .cta-btn {
      display: inline-block;
      padding: 0.75rem 2rem;
      border: 2px solid light-dark(rgba(15,40,100,0.4), rgba(255,255,255,0.6));
      border-radius: 2rem;
      color: light-dark(var(--color-main), white);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      transition: background 0.2s ease, border-color 0.2s ease;

      &:hover {
        background: light-dark(rgba(15,40,100,0.08), rgba(255,255,255,0.15));
        border-color: light-dark(var(--color-main), white);
      }
    }
  </style>
</Base>
