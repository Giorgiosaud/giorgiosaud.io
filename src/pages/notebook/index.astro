---
import { getCollection } from 'astro:content'
import { getPublishedNotes } from '@helpers/collections'
import { useTranslations } from '@i18n/utils'
import Base from '@templates/Base.astro'
import { runSearch } from '../../helpers/search'

const lang = 'en'
const t = useTranslations(lang)

const collections = await getCollection('collections')
const chipId = (id: string) => id.replace(/^\d{4}-\d{2}-\d{2}-/, '')

const url = Astro.url
const hasQuery = url.searchParams.has('q') || url.searchParams.has('collection')

let initialHtml = ''
if (!hasQuery) {
  const allNotes = await getPublishedNotes('en')
  const result = runSearch(allNotes, {
    lang: 'en',
    page: 1,
  })
  initialHtml = result.results
    .map(note => {
      const title = note.title
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
      const description = (note.description ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
      const coverAlt = (note.coverAlt ?? title).replace(/"/g, '&quot;')
      const collection = note.collections[0] ?? ''
      const imgVtn = `note-img-${note.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`
      const titleVtn = `note-title-${note.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`
      const imgHtml = note.coverSrc
        ? `<div class="card-thumb" style="view-transition-name:${imgVtn}"><img src="${note.coverSrc.replace(/"/g, '&quot;')}" alt="${coverAlt}" loading="lazy" /></div>`
        : ''
      return `<li class="note-card-item">
      <article aria-label="${title}" data-link="${note.href}" data-collection="${collection}">
        <div class="wrapper">
          ${imgHtml}
          <div class="title" style="view-transition-name:${titleVtn}" title="${title}"><h2>${title}</h2></div>
          <div class="description" title="${description}"><p>${description}</p></div>
        </div>
        <a href="${note.href}" class="card-link" aria-label="${coverAlt}"></a>
      </article>
    </li>`
    })
    .join('')
}
---

<Base title="Notebook" pathToTranslate="notebook">
  <section class="search-section">
    <h1>Notebook</h1>

    <div class="search-bar">
      <input
        id="search-input"
        type="search"
        placeholder="Search notes…"
        aria-label="Search notes"
        autocomplete="off"
      />
    </div>

    <div class="chip-bar" role="group" aria-label="Filter by collection">
      <button
        class="chip active"
        data-collection-chip=""
        aria-pressed="true"
      >
        All
      </button>
      {collections.map(col => (
        <button
          class="chip"
          data-collection-chip={chipId(col.id)}
          aria-pressed="false"
        >
          {col.data.title ?? chipId(col.id)}
        </button>
      ))}
    </div>

    <ul id="search-results" class="notes-grid" aria-live="polite" data-ssr={!hasQuery ? 'true' : 'false'}>
      {hasQuery
        ? <li class="loading"><p>Loading…</p></li>
        : <Fragment set:html={initialHtml} />
      }
    </ul>

    <nav id="pagination" class="pagination" aria-label="Pagination"></nav>
  </section>
</Base>

<script>
  import { initNotebookSearch } from '../../global/scripts/notebook-search'

  initNotebookSearch({
    lang: 'en',
    noResultsText: 'No notes found.',
    loadingText: 'Loading…',
    prevLabel: '← Previous',
    nextLabel: 'Next →',
  })
</script>

<style is:global>
  .search-section {
    padding-block: 2rem;
  }

  h1 {
    margin-bottom: 1.5rem;
  }

  .search-bar {
    margin-bottom: 1rem;
  }

  #search-input {
    width: 100%;
    max-width: 600px;
    padding: 0.65rem 1rem;
    border: 2px solid var(--color-main);
    border-radius: 0.5rem;
    font-size: 1rem;
    background: light-dark(var(--color-light), var(--color-dark));
    color: light-dark(var(--color-dark), var(--color-light));
    outline-color: var(--color-main);
  }

  #search-input::placeholder {
    color: light-dark(#475569, #94a3b8);
  }

  .chip-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .chip {
    padding: 0.35rem 0.85rem;
    border: 2px solid var(--color-main);
    border-radius: 9999px;
    background: transparent;
    color: light-dark(var(--color-dark), var(--color-light));
    cursor: pointer;
    font-size: 0.9rem;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }

  .chip.active,
  .chip:hover {
    background: var(--color-main);
    color: #fff;
  }

  .notes-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .no-results,
  .loading,
  .error {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
    opacity: 0.7;
  }

  /* ── Collection hues — on article (specificity 0,1,0 wins over inherited li default) ── */
  .note-card-item { --note-hue: 210; } /* fallback on li = inherited, not owned */

  [data-collection="ai"]                    { --note-hue: 174; }
  [data-collection="architecture"]          { --note-hue: 220; }
  [data-collection="astro"]                 { --note-hue: 24;  }
  [data-collection="common-issues"]         { --note-hue: 0;   }
  [data-collection="frontend"]              { --note-hue: 142; }
  [data-collection="industrial-engineering"]{ --note-hue: 270; }
  [data-collection="integration"]           { --note-hue: 190; }
  [data-collection="migration"]             { --note-hue: 40;  }
  [data-collection="patterns"]              { --note-hue: 320; }
  [data-collection="strategy"]              { --note-hue: 250; }

  /* ── Sticky-note cards ── */
  .notes-grid {
    align-items: start; /* let cards be their natural height */
  }

  .note-card-item {
    container: note / inline-size;
    /* slight tilt per position for a scattered-on-desk look */
    --_tilt: 0deg;
  }
  .note-card-item:nth-child(3n+1) { --_tilt: -1.1deg; }
  .note-card-item:nth-child(3n+2) { --_tilt:  0.7deg; }
  .note-card-item:nth-child(3n)   { --_tilt: -0.4deg; }

  .note-card-item article {
    --_fold: 28px;
    position: relative;
    transform: rotate(var(--_tilt));
    transform-origin: center bottom;
    transition: transform 0.25s cubic-bezier(.4,1.6,.5,1), box-shadow 0.25s ease;
    clip-path: polygon(0 0, calc(100% - var(--_fold)) 0, 100% var(--_fold), 100% 100%, 0 100%);
    box-shadow:
      3px 3px 0 1px light-dark(hsl(var(--note-hue) 60% 80%), hsl(var(--note-hue) 20% 25%)),
      6px 6px 0 2px light-dark(hsl(var(--note-hue) 55% 75%), hsl(var(--note-hue) 20% 20%)),
      0 6px 18px rgba(0,0,0,0.13);
  }

  .note-card-item article:hover {
    transform: rotate(0deg) translateY(-6px);
    box-shadow:
      3px 3px 0 1px light-dark(hsl(var(--note-hue) 60% 80%), hsl(var(--note-hue) 20% 25%)),
      6px 6px 0 2px light-dark(hsl(var(--note-hue) 55% 75%), hsl(var(--note-hue) 20% 20%)),
      0 12px 24px rgba(0,0,0,0.22);
    z-index: 5;
  }

  /* pin at the top center */
  .note-card-item article::after {
    content: '';
    position: absolute;
    top: -7px;
    left: 50%;
    translate: -50% 0;
    width: 13px;
    height: 13px;
    background: radial-gradient(
      circle at 35% 35%,
      hsl(var(--note-hue) 60% 80%),
      hsl(var(--note-hue) 50% 45%)
    );
    border-radius: 50%;
    box-shadow: 0 2px 5px rgba(0,0,0,0.35), inset 0 -1px 2px rgba(0,0,0,0.2);
    z-index: 4;
  }

  /* folded corner — on article so clip-path on .wrapper doesn't clip it */
  .note-card-item article::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    z-index: 3;
    width: var(--_fold);
    height: var(--_fold);
    background: linear-gradient(
      225deg,
      hsl(var(--note-hue) 40% 68%) 50%,
      transparent 50%
    );
    filter: drop-shadow(-1px 1px 2px rgba(0,0,0,0.18));
    pointer-events: none;
  }

  .note-card-item .wrapper {
    position: relative;
    /* pastel bg with faint ruled lines */
    background:
      repeating-linear-gradient(
        transparent,
        transparent calc(1.6rem - 1px),
        light-dark(
          hsl(var(--note-hue) 50% 84%),
          hsl(var(--note-hue) 30% 28%)
        ) calc(1.6rem - 1px),
        light-dark(
          hsl(var(--note-hue) 50% 84%),
          hsl(var(--note-hue) 30% 28%)
        ) 1.6rem
      ),
      light-dark(
        hsl(var(--note-hue) 70% 93%),
        hsl(var(--note-hue) 25% 18%)
      );
    background-position: 0 3.2rem; /* lines start below title */
    color: light-dark(
      hsl(var(--note-hue) 40% 18%),
      hsl(var(--note-hue) 15% 88%)
    );
    border-radius: 2px;
    padding: 1.1rem 1.1rem 1.25rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .note-card-item .card-thumb {
    border-radius: 0.4rem;
    overflow: hidden;
    margin-bottom: 0.2rem;
  }

  .note-card-item .card-thumb img {
    width: 100%;
    height: 72px;
    object-fit: cover;
    display: block;
  }

  .note-card-item .title h2 {
    font-size: clamp(0.95rem, 4cqw, 1.25rem);
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .note-card-item .description p {
    font-size: clamp(0.78rem, 3cqw, 0.88rem);
    opacity: 0.78;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    line-height: 1.6rem; /* align with ruled lines */
  }

  .note-card-item .card-link {
    position: absolute;
    inset: 0;
    display: block;
    text-indent: -9999px;
    z-index: 10;
  }

  /* ── Pagination ── */
  .pagination {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
    padding-block: 1rem;
  }

  .pagination-btn {
    padding: 0.5rem 1.25rem;
    border: 2px solid var(--color-main);
    border-radius: 0.5rem;
    background: transparent;
    color: light-dark(var(--color-dark), var(--color-light));
    cursor: pointer;
    font-size: 0.95rem;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }

  .pagination-btn:hover {
    background: var(--color-main);
    color: light-dark(var(--color-light), var(--color-dark));
  }

  .pagination-info {
    font-size: 0.9rem;
    opacity: 0.7;
  }
</style>
