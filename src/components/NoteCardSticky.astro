---
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import { isDraftInDevMode } from '@helpers/collections'
import { getLangFromUrl } from '@i18n/utils'

interface Props {
  note: CollectionEntry<'notes' | 'notas'>
}

const { note } = Astro.props
const lang = getLangFromUrl(Astro.url)
const href = lang === 'es' ? `/es/cuaderno/${note.id}` : `/notebook/${note.id}`
const collection = note.data.collections?.[0] as
  | {
      id?: string
    }
  | string
  | undefined
const collectionId =
  typeof collection === 'string' ? collection : (collection?.id ?? '')
const slug = collectionId.replace(/^\d{4}-\d{2}-\d{2}-/, '')
const imgVtn = `note-img-${note.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`
const titleVtn = `note-title-${note.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`
const cardVtn = `note-card-${note.id.replace(/[^a-zA-Z0-9_-]/g, '-')}`
const showDraftBadge = isDraftInDevMode(note.data)

const dateIso =
  note.data.lastUpdate?.toISOString() ?? note.data.publishDate.toISOString()
const dateLabel = note.data.lastUpdate
  ? `Updated ${note.data.lastUpdate.toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })}`
  : note.data.publishDate.toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
---

<li class="note-card-item">
  <article aria-label={note.data.title} data-link={href} data-collection={slug} style={`view-transition-name:${cardVtn}`}>
    {showDraftBadge && <span class="draft-badge">DRAFT</span>}
    <div class="wrapper">
      {note.data.cover && (
        <div class="card-thumb" style={`view-transition-name:${imgVtn}`}>
          <Image src={note.data.cover} alt={note.data.coverAlt ?? note.data.title} loading="lazy" width={400} height={72} />
        </div>
      )}
      <div class="title" style={`view-transition-name:${titleVtn}`} title={note.data.title}>
        <h2>{note.data.title}</h2>
      </div>
      <div class="description" title={note.data.description}>
        <p>{note.data.description}</p>
      </div>
      <footer class="card-meta">
        {slug && <span class="card-collection">{slug.replace(/-/g, ' ')}</span>}
        <time datetime={dateIso} class="card-date">{dateLabel}</time>
      </footer>
    </div>
    <a href={href} class="card-link" aria-label={note.data.coverAlt ?? note.data.title}></a>
  </article>
</li>

<style>
  .note-card-item {
    container: note / inline-size;
    --_tilt: 0deg;
    --note-hue: 210;
  }
  .note-card-item:nth-child(3n+1) { --_tilt: -1.1deg; }
  .note-card-item:nth-child(3n+2) { --_tilt:  0.7deg; }
  .note-card-item:nth-child(3n)   { --_tilt: -0.4deg; }

  [data-collection="ai"]                    { --note-hue: 174; }
  [data-collection="architecture"]          { --note-hue: 220; }
  [data-collection="astro"]                 { --note-hue: 24;  }
  [data-collection="common-issues"]         { --note-hue: 0;   }
  [data-collection="frontend"]              { --note-hue: 142; }
  [data-collection="industrial-engineering"]{ --note-hue: 270; }
  [data-collection="integration"]           { --note-hue: 190; }
  [data-collection="migration"]             { --note-hue: 40;  }
  [data-collection="patterns"]              { --note-hue: 320; }
  [data-collection="strategy"]              { --note-hue: 250; }

  article {
    --_fold: 28px;
    position: relative;
    transform: rotate(var(--_tilt));
    transform-origin: center bottom;
    transition: transform 0.25s cubic-bezier(.4,1.6,.5,1), box-shadow 0.25s ease;
    clip-path: polygon(0 0, calc(100% - var(--_fold)) 0, 100% var(--_fold), 100% 100%, 0 100%);
    color: light-dark(hsl(var(--note-hue) 40% 18%), hsl(var(--note-hue) 15% 88%));

    box-shadow:
      3px 3px 0 1px light-dark(hsl(var(--note-hue) 60% 80%), hsl(var(--note-hue) 20% 25%)),
      6px 6px 0 2px light-dark(hsl(var(--note-hue) 55% 75%), hsl(var(--note-hue) 20% 20%)),
      0 6px 18px rgba(0,0,0,0.13);
  }

  article:hover {
    transform: rotate(0deg) translateY(-6px);
    box-shadow:
      3px 3px 0 1px light-dark(hsl(var(--note-hue) 60% 80%), hsl(var(--note-hue) 20% 25%)),
      6px 6px 0 2px light-dark(hsl(var(--note-hue) 55% 75%), hsl(var(--note-hue) 20% 20%)),
      0 12px 24px rgba(0,0,0,0.22);
    z-index: 5;
  }

  article::after {
    content: '';
    position: absolute;
    top: -7px;
    left: 50%;
    translate: -50% 0;
    width: 13px;
    height: 13px;
    background: radial-gradient(
      circle at 35% 35%,
      hsl(var(--note-hue) 60% 80%),
      hsl(var(--note-hue) 50% 45%)
    );
    border-radius: 50%;
    box-shadow: 0 2px 5px rgba(0,0,0,0.35), inset 0 -1px 2px rgba(0,0,0,0.2);
    z-index: 4;
  }

  article::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    z-index: 3;
    width: var(--_fold);
    height: var(--_fold);
    background: linear-gradient(225deg, light-dark(hsl(var(--note-hue) 40% 68%), hsl(var(--note-hue) 20% 35%)) 50%, transparent 50%);
    filter: drop-shadow(-1px 1px 2px rgba(0,0,0,0.18));
    pointer-events: none;
  }

  .wrapper {
    position: relative;
    background:
      repeating-linear-gradient(
        transparent,
        transparent calc(1.6rem - 1px),
        light-dark(hsl(var(--note-hue) 50% 84%), hsl(var(--note-hue) 30% 28%)) calc(1.6rem - 1px),
        light-dark(hsl(var(--note-hue) 50% 84%), hsl(var(--note-hue) 30% 28%)) 1.6rem
      ),
      light-dark(hsl(var(--note-hue) 70% 93%), hsl(var(--note-hue) 25% 18%));
    background-position: 0 3.2rem;
    border-radius: 2px;
    padding: 1.1rem 1.1rem 1.25rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .card-thumb {
    border-radius: 0.4rem;
    overflow: hidden;
    margin-bottom: 0.2rem;
  }

  .card-thumb img {
    width: 100%;
    height: 72px;
    object-fit: cover;
    display: block;
  }

  .title h2 {
    font-size: clamp(0.95rem, 4cqw, 1.25rem);
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: inherit;
  }

  .description p {
    font-size: clamp(0.78rem, 3cqw, 0.88rem);
    opacity: 0.78;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    line-height: 1.6rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.4rem;
  }

  .card-collection {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: capitalize;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    background: light-dark(hsl(var(--note-hue) 60% 75%), hsl(var(--note-hue) 30% 35%));
    color: light-dark(hsl(var(--note-hue) 40% 15%), hsl(var(--note-hue) 15% 92%));
  }

  .card-date {
    font-size: 0.68rem;
    opacity: 0.65;
    margin-left: auto;
  }

  .card-link {
    position: absolute;
    inset: 0;
    display: block;
    text-indent: -9999px;
    z-index: 10;
  }

  .draft-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    z-index: 200;
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
