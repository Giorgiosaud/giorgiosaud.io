---
interface Props {
  lang?: 'en' | 'es'
  noteId?: string
}

const { lang = 'en', noteId = '' } = Astro.props

const i18n = {
  en: {
    buttonTitle: 'Generate summary',
    loading: 'Generating Summary...',
    unavailable: 'The summarization API is not available in this browser.',
    inputLang: 'en',
    outputLang: 'en',
    streamLang: 'en',
  },
  es: {
    buttonTitle: 'Generar resumen',
    loading: 'Generando resumen...',
    unavailable: 'La API de resumen no está disponible en este navegador.',
    inputLang: 'es',
    outputLang: 'es',
    streamLang: 'es',
  },
}

const t = i18n[lang]
---

<!-- Floating bubble button for summary generation (hidden until API is available) -->
<button
  id="generate-summary-bubble"
  class="summary-bubble"
  aria-label={t.buttonTitle}
  title={t.buttonTitle}
  data-note-id={noteId}
  data-lang={lang}
  hidden
>
  <span aria-hidden="true">🤖</span>
</button>

<!-- Emergent bubble/modal for summary result -->
<dialog
  id="summary-modal"
  class="summary-modal"
  aria-label={t.buttonTitle}
>
  <button id="close-summary-modal" class="close-summary-modal" aria-label="Close">&times;</button>
  <div id="summary-content" aria-live="polite" aria-atomic="false"></div>
</dialog>

<script define:vars={{ t }}>
  // Detect which summarizer API is available: Chrome's global Summarizer or Safari's window.ai.summarizer
  const SummarizerAPI = ("Summarizer" in self)
    ? self.Summarizer
    : (self.ai?.summarizer ?? null);

  if (SummarizerAPI) {
    const summaryBubble = document.getElementById("generate-summary-bubble");
    const summaryModal = document.getElementById("summary-modal");
    const summaryContent = document.getElementById("summary-content");
    const closeModalBtn = document.getElementById("close-summary-modal");

    summaryBubble.hidden = false;

    let markedModule = null;
    async function getMarked() {
      if (!markedModule) {
        const module = await import("https://cdn.jsdelivr.net/npm/marked/lib/marked.esm.js");
        markedModule = module.marked;
      }
      return markedModule;
    }

    async function summarizeContent() {
      summaryContent.innerHTML = `<p>${t.loading}</p>`;
      summaryModal.showModal();

      try {
        const options = {
          sharedContext:
            "This is a FrontEnd developer article. Use the same language as the text. Author is Giorgiosaud. Tone: informal but technical.",
          type: "key-points",
          format: "markdown",
          length: "medium",
        };

        const availability = await SummarizerAPI.availability(options);
        // Both APIs return 'unavailable' when not supported
        if (availability === "unavailable" || availability === "no") {
          summaryContent.innerHTML = `<p>${t.unavailable}</p>`;
          return;
        }

        const marked = await getMarked();

        const summarizer = await SummarizerAPI.create(options);
        const text = document.getElementById("content").innerText;

        // Both APIs support summarizeStreaming
        const stream = summarizer.summarizeStreaming(text);
        let result = "";
        let prevLength = 0;
        for await (const chunk of stream) {
          // Safari yields full accumulated text; Chrome yields only the new delta.
          // Detect by checking if chunk starts where we left off.
          if (chunk.length > prevLength && chunk.startsWith(result)) {
            result = chunk; // Safari: full text
          } else {
            result += chunk; // Chrome: delta
          }
          prevLength = result.length;
          summaryContent.innerHTML = marked.parse(result);
        }
      } catch (err) {
        summaryContent.innerHTML = `<p>${t.unavailable}</p>`;
        console.error("Summarizer error:", err);
      }
    }

    summaryBubble.addEventListener("click", () => {
      summarizeContent();
      // Move focus into dialog for keyboard/screen reader users
      setTimeout(() => closeModalBtn.focus(), 50);
    });

    closeModalBtn.addEventListener("click", () => {
      summaryModal.close();
      summaryContent.innerHTML = "";
      summaryBubble.focus();
    });

    summaryModal.addEventListener("click", (e) => {
      if (e.target === summaryModal) {
        summaryModal.close();
        summaryContent.innerHTML = "";
      }
    });
  }
</script>
<script>
  import { trackEvent } from "@helpers/datalayer";

  const btn = document.getElementById(
    "generate-summary-bubble",
  ) as HTMLButtonElement | null;
  btn?.addEventListener("click", () => {
    trackEvent({
      event: "ai_summarizer_open",
      note_id: btn.dataset.noteId ?? "",
      lang: (btn.dataset.lang ?? "en") as "en" | "es",
    });
  });
</script>

<style>
  .summary-bubble[hidden] { display: none; }
  .summary-bubble {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    @media (width < 48rem) {
      bottom: calc(4.5rem + 1rem);
    }
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: conic-gradient(from 180deg, #7c3aed, #2563eb, #06b6d4, #7c3aed);
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    cursor: pointer;
    z-index: 2000;
    border: 2px solid rgba(255,255,255,0.15);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .summary-bubble:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(124, 58, 237, 0.55);
  }

  .summary-modal {
    position: fixed;
    bottom: 6rem;
    right: 2rem;
    @media (width < 48rem) {
      bottom: calc(4.5rem + 1rem + 4rem);
      right: 1rem;
      left: 1rem;
      width: auto;
    }
    width: 320px;
    max-width: calc(100vw - 2rem);
    max-height: 70vh;
    overflow-y: auto;
    background: #fff;
    border-radius: 1.5rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    padding: 2rem 1.5rem 1.5rem 1.5rem;
    border: none;
    z-index: 2100;
    flex-direction: column;
    gap: 1rem;
    animation: bubbleIn 0.3s ease;
    &[open] { display: flex; }
  }
  .summary-modal::backdrop { background: transparent; }
  code {
    background: #f4f4f4;
    padding: 0.2rem 0.4rem;
    border-radius: 0.3rem;
  }

  .close-summary-modal {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #333;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    &:hover { color: #000; }
  }

  #summary-content {
    font-size: 1rem;
    color: #222;
  }

  @keyframes bubbleIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
